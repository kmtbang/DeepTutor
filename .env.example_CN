# ==============================================================================
# DeepTutor 环境配置文件
# ==============================================================================
# 请将此文件复制为 `.env` 并填写相应的值。
# [必填] 表示必须配置的字段，[可选] 表示可选配置的字段。

# ==============================================================================
# 服务器端口配置
# ==============================================================================

# [可选] 后端 API 服务器端口
BACKEND_PORT=8001

# [可选] 前端服务器端口
FRONTEND_PORT=3782

# ==============================================================================
# LLM 配置（大语言模型）
# ==============================================================================
# 所有 AI 功能（聊天、研究、解题等）使用的主要大语言模型

<<<<<<< HEAD
# NEXT_PUBLIC_API_BASE=http://your-server-ip:8001（可选）

# ============================================================================
# LLM 部署模式配置
# ============================================================================
# 控制 DeepTutor 如何选择 LLM 提供商。
#
# 选项：
#   - hybrid（默认）：同时使用 API 和本地提供商。活动的提供商优先。
#   - api：仅使用云端 API 提供商（OpenAI、Anthropic、DeepSeek 等）
#   - local：仅使用本地/自托管提供商（Ollama、LM Studio、vLLM 等）
#
# 在 hybrid 模式下，您可以通过设置界面添加 API 和本地提供商，
# 并通过将其设为"活动"来在它们之间切换。

LLM_MODE=api

# ============================================================================
# LLM（大语言模型）配置
# ============================================================================
# 配置用于推理、生成和对话的主要 AI 模型。
# 支持 OpenAI 兼容 API（OpenAI、Azure OpenAI、DeepSeek、Qwen 等）
# 以及本地服务器（Ollama、LM Studio、vLLM、llama.cpp）。
#
# 注意：这些环境变量作为默认/后备配置。
# 您也可以通过设置界面添加提供商，活动时将优先使用。

# LLM 服务提供商类型
# 选项：openai、azure_openai、ollama、anthropic
LLM_BINDING=openai

# LLM 模型名称
# 云端示例：gpt-4o、gpt-4o-mini、deepseek-chat、claude-3-5-sonnet-20241022
# 本地示例：llama3.2、qwen2.5、mistral-nemo、deepseek-r1
LLM_MODEL=gpt-4o

# LLM API 端点 URL
# 云端示例：
#   - OpenAI：https://api.openai.com/v1
#   - DeepSeek：https://api.deepseek.com
#   - Anthropic：https://api.anthropic.com/v1
# 本地示例：
#   - Ollama：http://localhost:11434/v1
#   - LM Studio：http://localhost:1234/v1
#   - vLLM：http://localhost:8000/v1
#   - llama.cpp：http://localhost:8080/v1
LLM_HOST=https://api.xi-ai.cn/v1

# LLM API 认证密钥
# 云端 API 必需，本地部署可选
# 对于 Ollama，可以使用任意字符串（如 "ollama"）
LLM_API_KEY=sk-Rizk4P9TGGWcoOSvE17370C94aD64090A604AfC6Aa2f37F0
